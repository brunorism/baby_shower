name: Deploy to GitHub Pages

on:
  push:
    branches: [ main ]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Inject API URL
        run: |
          # This replaces the placeholder with your actual secret URL in the JS file
          sed -i 's|ENV_SHEETY_URL|${{ secrets.SHEETY_API_URL }}|g' script.js

      - name: Deploy to GitHub Pages
        uses: JamesIves/github-pages-deploy-action@v4
        with:
          folder: . # The folder your files are in
          branch: gh-pages